# Nao cachear o index.html — garante que deploys novos
# sejam carregados sem precisar limpar cache do browser.
# Os JS/CSS em /assets/ TEM hash no nome, entao podem ser cacheados.
<FilesMatch "index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# SPA: todas as rotas redirecionam pra index.html
RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L,QSA]
